{
  "name": "GEN+ / AECODE Design Tokens x7",
  "version": "3.0.0",
  "codename": "Command Suisse",
  "mode": "demo",
  "philosophy": "Precisión quirúrgica + confianza de banco suizo + velocidad de Raycast + inteligencia de Perplexity + sobriedad de sala de control NASA. Si no mejora la velocidad de decisión o no reduce la ansiedad del usuario, se elimina.",
  "runtime": { "css": "tokens.css", "tailwindPreset": "tailwind.config.js", "stack": "vanilla single-file (no build)" },
  "dataPolicy": {
    "classification": "MOCK GEN+ - conectar a API real",
    "iso19650": true,
    "pdplPeru": true,
    "requiresDemoModeToggle": true,
    "sensitiveDataSegregation": "No project/client confidential data is stored in this static demo."
  },
  "typography": {
    "body": "'Plus Jakarta Sans', Inter, system-ui, sans-serif",
    "display": "'Plus Jakarta Sans', Inter, system-ui, sans-serif",
    "mono": "'JetBrains Mono', ui-monospace, monospace",
    "weights": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700, "black": 800 },
    "scalePx": [12, 13, 14, 16, 18, 20, 24, 32, 40, 56, 72],
    "fluid": {
      "hero": "clamp(2.35rem, 1.45rem + 4.0vw, 4.6rem)",
      "metric": "clamp(2rem, 1.3rem + 2.6vw, 3.25rem)",
      "section": "clamp(1.6rem, 1.15rem + 1.8vw, 2.5rem)"
    },
    "tracking": { "tight": "-0.022em", "snug": "-0.012em", "eyebrow": "0.16em" },
    "numeric": "font-variant-numeric: tabular-nums en toda métrica"
  },
  "color": {
    "background": {
      "light": { "base": "#FFFFFF", "soft": "#F8FAFC", "muted": "#F1F5F9" },
      "darkCommand": { "0": "#02060F", "1": "#040F20", "2": "#06121F" }
    },
    "primary": { "default": "#2165FF", "hover": "#1B4ED8", "active": "#132D66", "200": "#B9CEFF" },
    "semanticAEC": {
      "avanceFisico": { "text": "#0891B2", "accent": "#22D3EE" },
      "riesgoCritico": { "text": "#EA580C", "accent": "#F97316", "danger": "#DC2626" },
      "exitoFinanciero": { "text": "#15A34A", "accent": "#22C55E", "soft": "#86EFAC" },
      "bloqueo": { "text": "#9333EA", "accent": "#C084FC" },
      "advertencia": { "text": "#B45309", "accent": "#F59E0B" },
      "iaEjecutando": "#2165FF"
    },
    "neutral": {
      "textPrimary": "#0B1220",
      "textSecondary": "#475569",
      "textTertiary": "#64748B",
      "border": "#E2E8F0",
      "borderStrong": "#CBD5E1"
    }
  },
  "space": { "grid": "4px estricto", "scale": [4, 8, 12, 16, 20, 24, 28, 32, 40, 48, 56, 64, 80, 96, 128], "cardPadding": 24, "maxWidth": 1280 },
  "radius": { "xs": "8px", "sm": "12px", "md": "16px", "lg": "20px", "xl": "24px", "2xl": "28px", "pill": "999px", "cardDefault": "20px" },
  "shadow": {
    "card": "0 10px 15px -3px rgb(2 6 23 / 0.07), 0 4px 6px -4px rgb(2 6 23 / 0.05)",
    "innerBorder": "1px solid #E2E8F0",
    "elevated": "0 24px 48px -16px rgb(2 6 23 / 0.18)",
    "command": "0 40px 120px -28px rgb(2 6 23 / 0.55)",
    "focusRing": "0 0 0 3px rgb(33 101 255 / 0.32)"
  },
  "motion": {
    "durations": { "fast": "140ms", "base": "220ms", "slow": "320ms" },
    "easing": "cubic-bezier(0.23, 1, 0.32, 1)",
    "spring": "cubic-bezier(0.34, 1.4, 0.64, 1)",
    "hover": "translateY(-2px) + box-shadow; press: scale(0.98-0.99)",
    "reducedMotion": "Respect prefers-reduced-motion; remove movement, keep opacity/color state."
  },
  "componentStates": ["default", "hover", "focus", "active", "disabled", "loading", "error", "empty", "selected"]
}
